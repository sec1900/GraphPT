# === 敏感信息（含真实密钥，绝不上传）===
.env
.env.bak
.env.*.bak

# === Python 缓存 ===
.temp/
__pycache__/
*.pyc
*.pyo
*.pyd

# === 运行时数据 / 备份 / 诊断 ===
data/
backup/
debug/
artifacts/

# === 大体积资源（工具二进制 / PoC 库 / skill 知识库）===
# 忽略 tools 下所有内容，但保留目录结构和 tool.yaml / README.md / 自研脚本工具
tools/**
!tools/**/
!tools/**/tool.yaml
!tools/**/README.md
!tools/**/*.py
# 但第三方工具自带的安装目录（如 nmap 的 zenmap）整体忽略，不要被 *.py 规则捞回来
tools/nmap/zenmap/
tools/nmap/ndiff.py
res/toolkit/
res/poc/
res/skills/

# === 克隆的第三方工具仓库（3.5G，绝不入库）===
github_repos/

# === 大体积字典 / 指纹库 / payload（按需用脚本生成或本地放置，不入库）===
res/wordlists/*.txt
res/knowledge/payloads/
# 保留字典说明文档
!res/wordlists/README.md

# === 前端第三方库（CDN 或构建时拉取，不入库）===
graphpt/web/static/vendor/

# === 杂项 ===
/python
.claude/settings.local.json
# 项目工作区产物(如果有人在仓库根用 GRAPHPT_ALLOW_REPO_ROOT=1 启动)
.graphpt/
findings/
operations/
attempts.jsonl
# 启动器产物
bin/__pycache__/

!.gitkeep

dump.rdb
*.png
.playwright-mcp/
