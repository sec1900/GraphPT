# ============================================================
# GraphPT 配置文件 — 复制为 .env 后修改
# ============================================================

# Neo4j 图数据库（local = tools/neo4j，默认密码 graphpt123）
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="graphpt123"

# Redis（工具锁、状态缓存、心跳）
GRAPHPT_REDIS_URL="redis://localhost:6379/0"

# 调度器总并发槽位（多资产均分）
# 例: 10 → 2 个资产各得 5 个, 4 个资产各得 2 个
GRAPHPT_CONCURRENCY="4"

# ---- 可选：AI 接口 ----
GRAPHPT_AI_BASE_URL="https://api.deepseek.com"
GRAPHPT_AI_MODEL="deepseek-v4-pro"
GRAPHPT_AI_API_KEY="sk-your-key-here"

# ---- 可选：FOFA / Shodan / Hunter ----
FOFA_EMAIL=
FOFA_KEY=
SHODAN_API_KEY=
HUNTER_API_KEY=

# ---- 可选：GitHub Token / 天眼查 ----
GITHUB_TOKEN=
TIANYANCHA_TOKEN=

# ---- 代理（留空不用）----
GRAPHPT_PROXY_URL=
