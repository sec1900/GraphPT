# ============================================================
# GraphPT 配置文件 — 复制为 .env 后修改
# ============================================================

# Neo4j 图数据库（local = tools/neo4j，默认密码 graphpt123）
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="graphpt123"

# Redis（工具锁、状态缓存、心跳）
GRAPHPT_REDIS_URL="redis://localhost:6379/0"

# 调度器总并发槽位（多资产均分）
# 不设则自动检测物理内存分档：
#   <4GB→1, <8GB→1, <16GB→2, <32GB→4, <64GB→6, ≥64GB→8
#   同时不超过 CPU 核心数的一半
# GRAPHPT_CONCURRENCY="2"

# ---- 工具执行控制 ----
# 批量扫描每组大小（减少单次子进程负载）
GRAPHPT_CHUNK_SIZE="100"
# 活性超时 — 进程无输出超过此秒数 → kill
GRAPHPT_STALE_TIMEOUT="300"
# 单工具绝对上限（秒），默认1800(30min)，0=不限
GRAPHPT_MAX_TOOL_TIME="1800"
# 人工验证宽限期 — 检测到反爬验证后等用户操作的秒数
GRAPHPT_VERIFICATION_GRACE="600"
# 错误日志自动清理 — 超过此小时数的 ErrorLog 自动删除，0=不自动清理
GRAPHPT_ERROR_TTL_HOURS="24"
# 子进程内存上限（MB），0=不限；不设则自动取 总内存×60%÷并发数（512~8192MB）
# GRAPHPT_MAX_TOOL_MEM_MB="4096"
# 扫描层并行数上限；不设则自动取并发数（2~CPU/2）
# GRAPHPT_LAYER_WORKERS="3"
# 单次调度每个工具最大目标数，大规模资产自动分批
GRAPHPT_MAX_TARGETS="100"
# 子进程 stdout 轮询间隔（秒）
GRAPHPT_POLL_INTERVAL="2"
# 调度器锁 TTL（秒）
GRAPHPT_SCHEDULER_LOCK_TTL="600"
# 连续无产出轮数后退出
GRAPHPT_DRY_ROUNDS_EXIT="2"

# ---- 可选：AI 接口 ----
GRAPHPT_AI_BASE_URL="https://api.deepseek.com"
GRAPHPT_AI_MODEL="deepseek-v4-pro"
GRAPHPT_AI_API_KEY="sk-your-key-here"

# ---- 可选：FOFA / Shodan / Hunter ----
FOFA_EMAIL=
FOFA_KEY=
SHODAN_API_KEY=
HUNTER_API_KEY=

# ---- 可选：GitHub Token / 天眼查 ----
GITHUB_TOKEN=
TIANYANCHA_TOKEN=

# ---- 代理（留空不用）----
GRAPHPT_PROXY_URL=
