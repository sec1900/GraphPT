# ============================================================
# GraphPT — Docker Compose 环境变量
# 复制此文件为 .env 并根据实际环境修改
# ============================================================

# ---- Neo4j ----
NEO4J_USER=neo4j
NEO4J_PASSWORD=graphpt123

# ---- Celery ----
CELERY_CONCURRENCY=4

# ---- Agent ----
GRAPHPT_ASSET_ID=default

