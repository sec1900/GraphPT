# ============================================================
# GraphPT 配置文件
# 注意：本文件包含敏感信息，请勿提交到仓库
# ============================================================

# ---- 数据库 ----
# SQLite 文件路径（相对或绝对路径均可）
GRAPHPT_DB="data/db/graphpt.db"
# Neo4j 图数据库连接
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="graphpt123"
# Celery 消息队列
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
# Celery Worker 并发数
CELERY_CONCURRENCY="10"
# 调度器总并发槽位（默认取 CELERY_CONCURRENCY，多资产均分）
GRAPHPT_CONCURRENCY="10"
# 批量扫描每组大小（减少单次子进程负载，默认 100）
GRAPHPT_CHUNK_SIZE="100"

# ---- 目录路径 ----
# PoC 资源目录（留空默认 ./res/poc）
GRAPHPT_POC_DIR="./res/poc"
# 工具资源目录（留空默认 ./res/toolkit）
GRAPHPT_TOOLKIT_DIR="./res/toolkit"
# 项目工作区目录（留空默认 ./data/projects）
GRAPHPT_PROJECTS_DIR="./data/projects"
# ---- AI 接口（OpenAI 兼容格式）----
# API 基础地址
GRAPHPT_AI_BASE_URL="https://api.deepseek.com"
# 模型名称
GRAPHPT_AI_MODEL="deepseek-v4-pro"
# API 密钥（涉密，请勿泄露）
GRAPHPT_AI_API_KEY="sk-"
# 接口协议类型：chat_completions / responses / messages
GRAPHPT_AI_WIRE_API="chat_completions"
# 单次请求超时（秒）
GRAPHPT_AI_TIMEOUT_S="60"
# 请求失败最大重试次数
GRAPHPT_AI_MAX_RETRIES="3"
# 输出 token 上限（思考模型需较大值，默认 65536）
GRAPHPT_AI_MAX_TOKENS="65536"
# Reasoning 模式（auto=自动检测 / enabled=强制开启 / disabled=关闭）
GRAPHPT_REASONING_MODE="enabled"
# Reasoning 深度（low / medium / high / xhigh，留空=不传；xhigh 仅 chat_completions 原生支持）
GRAPHPT_REASONING_EFFORT="xhigh"
# 模型不支持 reasoning 时的行为（disable=静默降级 / error=报错）
GRAPHPT_REASONING_FALLBACK="disable"

# ---- CLI 上下文压缩阈值 ----
# 声明模型上下文窗口（token），CLI 据此自动换算字符预算（×2.0×0.75）。
# v4-pro 上下文 1M → 预算自动抬到 ~1.5M 字符，少触发压缩、吃满长上下文。
GRAPHPT_AI_CONTEXT_TOKENS="1000000"
# 显式字符预算（最高优先，留空=用上面窗口换算；都空=保守默认 400000）。
GRAPHPT_CLI_COMPACT_AT_CHARS=

# ---- 审批 ----
# 工具审批模式（auto_approve=全部自动批准，跳过审批 / timeout_auto_approve=超时后自动批准 / manual=手动审批）
GRAPHPT_APPROVAL_MODE="auto_approve"

# ---- 执行控制 ----
# AI 最大并发请求数（同时在飞的 AI API 请求上限，0 = 不限制）
# 使用第三方中转/代理 API 时建议设为 1~3，防止 503 No available accounts
GRAPHPT_AI_MAX_CONCURRENT="3"
# 并行 Worker 数量（同时执行的 Agent 数）
GRAPHPT_PARALLEL_WORKERS="3"
# HTTP/HTTPS 代理地址（如 http://127.0.0.1:7890，留空不使用代理）
GRAPHPT_PROXY_URL="http://192.168.166.166:16666"

# ---- Docker 沙箱（可选）----
# 是否启用 Docker 沙箱执行工具命令（true / false，留空默认不启用）
# Docker 工具镜像名称（留空默认 graphpt-tools:latest）

# ---- WebDAV 同步（可选）----
# WebDAV 服务入口地址
# WebDAV 根目录路径
# WebDAV 用户名
GRAPHPT_WEBDAV_USERNAME=
# WebDAV 密码
GRAPHPT_WEBDAV_PASSWORD=

# ---- 浏览器自动化（可选）----
# 是否以无头模式运行 Playwright 浏览器（true / false，留空默认 true）

# ---- 资产搜索引擎（可选）----
# FOFA 搜索引擎（https://fofa.info）
FOFA_EMAIL=
FOFA_KEY=
# Shodan 搜索引擎（https://shodan.io）
SHODAN_API_KEY=
# Hunter 鹰图搜索引擎（https://hunter.qianxin.com）
HUNTER_API_KEY=

# ---- 公司资产发现（可选，不配置则使用免费数据源）----
# GitHub Token（提升 API 搜索限额）
GITHUB_TOKEN=
# 天眼查 API Token（https://open.tianyancha.com）
TIANYANCHA_TOKEN=

# ---- 调试 ----
# 调试模式（true 启用后，任务消息流中会输出 [debug] 诊断信息，且启动时会生成 debug/ui.xlsx、debug/interface.xlsx、debug/database.xlsx）
# 调试产物输出目录（相对路径默认相对项目根目录）
GRAPHPT_DEBUG_DIR="data/debug"
GRAPHPT_VALIDATION_MAILBOX_URL="https://mail.example.com/inbox"
GRAPHPT_VALIDATION_CALLBACK_URL="https://callback.example.com/"
GRAPHPT_VALIDATION_OOB_DOMAIN="oob.example.com"
GRAPHPT_VALIDATION_INFRA_HOSTS="exploit-server.net,mail.example.com,callback.example.com"
