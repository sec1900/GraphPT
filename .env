# ============================================================
# GraphPT 配置文件
# 注意：本文件包含敏感信息，请勿提交到仓库（.gitignore 已排除）
# ============================================================


# ═══════════════════════════════════════════════════════════
# 1. 数据库 & 消息队列
# ═══════════════════════════════════════════════════════════

# Neo4j 图数据库（直读 os.getenv，不走 AppSettings）
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="graphpt123"

# Celery / Redis 消息队列（直读 os.getenv，不走 AppSettings）
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"
CELERY_CONCURRENCY="10"

# SQLite 项目数据库路径（相对路径默认相对项目根目录）
GRAPHPT_DB="data/db/graphpt.db"

# Redis 独立连接地址（留空则自动从 CELERY_BROKER_URL 解析）
# GRAPHPT_REDIS_URL="redis://localhost:6379/0"

# 调度器总并发槽位（默认取 CELERY_CONCURRENCY，多资产均分）
GRAPHPT_CONCURRENCY="10"


# ═══════════════════════════════════════════════════════════
# 2. 目录路径
# ═══════════════════════════════════════════════════════════

GRAPHPT_POC_DIR="./res/poc"
GRAPHPT_TOOLKIT_DIR="./res/toolkit"
GRAPHPT_PROJECTS_DIR="./data/projects"
GRAPHPT_DEBUG_DIR="data/debug"


# ═══════════════════════════════════════════════════════════
# 3. AI 接口（OpenAI 兼容格式）
# ═══════════════════════════════════════════════════════════

GRAPHPT_AI_BASE_URL="https://api.deepseek.com"
GRAPHPT_AI_MODEL="deepseek-v4-pro"
GRAPHPT_AI_API_KEY="sk-f373dc3302294abe89bc1ff9217181d4"
GRAPHPT_AI_WIRE_API="chat_completions"
GRAPHPT_AI_TIMEOUT_S="60"
GRAPHPT_AI_MAX_RETRIES="3"
GRAPHPT_AI_MAX_TOKENS="65536"
GRAPHPT_AI_MAX_CONCURRENT="3"
GRAPHPT_AI_CONTEXT_TOKENS="1000000"

# Reasoning 控制
GRAPHPT_REASONING_MODE="enabled"
GRAPHPT_REASONING_EFFORT="xhigh"
GRAPHPT_REASONING_FALLBACK="disable"


# ═══════════════════════════════════════════════════════════
# 4. CLI
# ═══════════════════════════════════════════════════════════

# 显式上下文压缩字符预算（留空=自动根据 AI_CONTEXT_TOKENS 换算）
GRAPHPT_CLI_COMPACT_AT_CHARS=


# ═══════════════════════════════════════════════════════════
# 5. 工具执行控制
# ═══════════════════════════════════════════════════════════

# 批量扫描每组大小（减少单次子进程负载）
GRAPHPT_CHUNK_SIZE="100"

# 活性超时 — 进程持续有 stdout 输出 → 永不超时；无输出超过此秒数 → kill
GRAPHPT_STALE_TIMEOUT="300"

# 单工具绝对上限（可选兜底），0=不限
GRAPHPT_MAX_TOOL_TIME="0"

# 单次调度每个工具最大目标数，大规模资产自动分批
GRAPHPT_MAX_TARGETS="100"

# 子进程 stdout 轮询间隔（秒）
GRAPHPT_POLL_INTERVAL="2"

# 子进程内存上限（MB），0=不限；nuclei 15K 模板可达 1GB+
# 超过则 kill 并记录 error（不中断扫描继续下一批）
GRAPHPT_MAX_TOOL_MEM_MB="4096"

# ── 日志 / 临时文件自动清理 ──
# 每个工具目录最多保留日志文件数
GRAPHPT_LOG_MAX_FILES="50"
# 日志文件最长保留时间（小时），超期删除
GRAPHPT_LOG_MAX_AGE_H="168"
# 临时文件最长保留时间（分钟），超期删除
GRAPHPT_TMP_MAX_AGE_M="60"

# 调度器锁 TTL（秒），正常完成后主动释放，此值兜底
GRAPHPT_SCHEDULER_LOCK_TTL="600"

# 调度器心跳 key TTL（秒）
GRAPHPT_SCHEDULER_HEARTBEAT_TTL="3600"

# 调度器心跳僵死阈值（秒），超过此值无心跳 → 自动释放锁
GRAPHPT_SCHEDULER_HEARTBEAT_STALE="300"

# OOB interactsh-client 启动超时（秒）
GRAPHPT_OOB_START_TIMEOUT="20"

# 调度器运行模式（legacy / shadow / event / watchdog）
# GRAPHPT_SCHEDULER_MODE="event"

# 单条 Bash 命令执行超时上限（秒），工具 timeout 会被钳到此值
# GRAPHPT_CMD_TIMEOUT_MAX_S="86400"


# ═══════════════════════════════════════════════════════════
# 6. 审批 & 代理 & 并发
# ═══════════════════════════════════════════════════════════

GRAPHPT_APPROVAL_MODE="auto_approve"
# 审批自动通过等待时间（秒），仅 timeout_auto_approve 模式生效
# GRAPHPT_APPROVAL_TIMEOUT_S="10"

GRAPHPT_PARALLEL_WORKERS="3"
GRAPHPT_PROXY_URL="http://192.168.166.166:16666"


# ═══════════════════════════════════════════════════════════
# 7. 日志缓存
# ═══════════════════════════════════════════════════════════

# 日志轮转大小阈值（MB）
# GRAPHPT_CACHE_ROTATE_MB="5"
# 日志轮转行数阈值
# GRAPHPT_CACHE_ROTATE_LINES="50000"
# 日志保留文件数
# GRAPHPT_CACHE_RETENTION_COUNT="40"
# 日志压缩延迟（小时）
# GRAPHPT_CACHE_COMPRESS_AFTER_H="24"


# ═══════════════════════════════════════════════════════════
# 8. 浏览器自动化（Playwright）
# ═══════════════════════════════════════════════════════════

# 是否无头模式（true / false）
# GRAPHPT_BROWSER_HEADLESS="true"


# ═══════════════════════════════════════════════════════════
# 9. Docker 沙箱（可选）
# ═══════════════════════════════════════════════════════════

# 是否启用 Docker 沙箱执行工具（true / false）
# GRAPHPT_DOCKER_MODE="false"
# Docker 工具镜像名称
# GRAPHPT_DOCKER_IMAGE="graphpt-tools:latest"


# ═══════════════════════════════════════════════════════════
# 10. WebDAV 同步（可选）
# ═══════════════════════════════════════════════════════════

GRAPHPT_WEBDAV_URL=
GRAPHPT_WEBDAV_BASE_DIR=
GRAPHPT_WEBDAV_USERNAME=
GRAPHPT_WEBDAV_PASSWORD=


# ═══════════════════════════════════════════════════════════
# 11. 资产搜索引擎（可选）
# ═══════════════════════════════════════════════════════════

GRAPHPT_FOFA_EMAIL=
GRAPHPT_FOFA_KEY=
GRAPHPT_SHODAN_API_KEY=
GRAPHPT_HUNTER_API_KEY=


# ═══════════════════════════════════════════════════════════
# 12. 公司资产发现（可选）
# ═══════════════════════════════════════════════════════════

GRAPHPT_GITHUB_TOKEN=
GRAPHPT_TIANYANCHA_TOKEN=


# ═══════════════════════════════════════════════════════════
# 13. OOB 带外交互验证
# ═══════════════════════════════════════════════════════════

GRAPHPT_VALIDATION_MAILBOX_URL="https://mail.example.com/inbox"
GRAPHPT_VALIDATION_CALLBACK_URL="https://callback.example.com/"
GRAPHPT_VALIDATION_OOB_DOMAIN="oob.example.com"
GRAPHPT_VALIDATION_INFRA_HOSTS="exploit-server.net,mail.example.com,callback.example.com"


# ═══════════════════════════════════════════════════════════
# 14. 调试
# ═══════════════════════════════════════════════════════════

# 调试模式（true 开启后输出诊断信息 + 生成 debug/*.xlsx）
# GRAPHPT_DEBUG="false"
# AI Token 预算覆盖（0=不限制）
# GRAPHPT_MAX_TOKEN_BUDGET="0"
